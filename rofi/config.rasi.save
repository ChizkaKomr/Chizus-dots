@import "~/.config/wallust/wallust-colors.rasi"

configuration {
    show-icons:          true;
    display-drun:        ""; 
    drun-display-format: "{name}";
}

* {
    bg: #203D46A4;
    s-fg: #203D46; /*colors for selected ones*/
    fg: #c2fcfc;
    s-bg: #c2fcfc;
    border: #1adeba;
}

window {
    width:            30%;
    border:           2px;
    border-color:     @border;
    background-color: @bg;
    padding:          15px;
    border-radius:    18px;
}

inputbar {
    children: [ entry ];
    border:   0px;
}

entry, prompt {
    background-color: transparent;
    text-color:       @fg;
}

listview {
    columns:      1;
    lines:        8;
    spacing:      5px;
    fixed-height: false;
    scrollbar:    false;
    border:       0px;
}

element {
    orientation:   horizontal;
    children:      [ element-icon, element-text ];
    spacing:       12px;
    padding:       8px;
    border-radius: 12px;
}

element-icon {
    size: 1.5em;
}

element-text, element-icon {
    background-color: transparent;
    text-color:       inherit;
}

element.normal.normal, element.alternate.normal {
    background-color: transparent;
    text-color:       @fg;
}

element.selected.normal {
    background-color: @s-bg;
    text-color:       @s-fg;
}

textbox-num-sep, num-filtered-rows, num-rows {
    enabled: false;
}




