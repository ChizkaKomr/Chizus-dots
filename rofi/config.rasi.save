configuration {
    show-icons:          true;
    display-drun:        ""; 
    drun-display-format: "{name}";
}

* {
    bg: #203D46A4; 
    fg: #c2fcfc;
    fg-s: #c2fcfca6;
}

window {
    width:            30%;
    border:           2px;
    border-color:     @fg;
    background-color: @bg;
    padding:          15px;
    border-radius:    16px;
}

inputbar {
    children: [ entry ];
    border:   0px;
}

entry, prompt {
    background-color: @bg;
    text-color:       @fg;
}

listview {
    columns:      1;
    lines:        8;
    spacing:      5px;
    fixed-height: false;
    scrollbar:    false;
    border:       0px;
}

element {
    orientation:   horizontal;
    children:      [ element-icon, element-text ];
    spacing:       12px;
    padding:       8px;
    border-radius: 12px;
}

element-icon {
    size: 1.5em;
}

element-text, element-icon {
    background-color: transparent;
    text-color:       inherit;
}

element.normal.normal, element.alternate.normal {
    background-color: transparent;
    text-color:       @fg;
}

element.selected.normal {
    background-color: @fg;
    text-color:       @bg-s;
}

textbox-num-sep, num-filtered-rows, num-rows {
    enabled: false;
}
